            "source": "if (doc['message.keyword'].size() > 0) { def msg = doc['message.keyword'].value; def client_pattern = /\"client\":\"([^\\/\"]+)/; def matcher = client_pattern.matcher(msg); if (matcher.find()) { return matcher.group(1); } def service_pattern2 = /\"service\":\"([^\"]+)\"/; def matcher2 = service_pattern2.matcher(msg); if (matcher2.find()) { def service = matcher2.group(1); if (service.startsWith('host/')) { def parts = service.split('/'); if (parts.length > 1) { def hostname_domain = parts[1]; def hostname_parts = hostname_domain.split('\\\\.'); return hostname_parts[0]; } } } }"
